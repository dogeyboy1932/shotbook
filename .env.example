# =============================================================================
# ShotBook — ALL configuration in ONE place.
#
# Copy this file to `.env` (gitignored) and fill in the values. Every part of
# the system reads from this single root file:
#   - Frontend  : Vite loads VITE_* from here (frontend/vite.config.ts envDir: '..')
#   - Renderer  : renderer/config.py    (BVG_* + ANTHROPIC_API_KEY)
#   - Ingestion : ingestion/config.py   (BVG_* + ANTHROPIC_API_KEY)
#   - Deploy    : scripts/start-vm.sh reads VM_* here and writes the VM's own
#                 ~/shotbook/.env from the BVG_*/ANTHROPIC_API_KEY lines below.
# Never commit real secrets — `.env` is gitignored.
# =============================================================================

# -----------------------------------------------------------------------------
# Frontend (Vite, build-time). Only VITE_*-prefixed vars reach the browser bundle.
# -----------------------------------------------------------------------------
VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_xxx        # publishable/anon key (browser-safe)
VITE_VM_BASE_URL=http://localhost:8004           # SSH-tunnel the VM renderer to this

# -----------------------------------------------------------------------------
# Renderer + ingestion runtime (BVG_ prefix). DATABASE_URL uses the Supabase
# POOLER (the VM is IPv4-only); note the aws-1 host.
# -----------------------------------------------------------------------------
BVG_DATABASE_URL=postgresql+asyncpg://postgres.<ref>:<password>@aws-1-us-east-1.pooler.supabase.com:5432/postgres
ANTHROPIC_API_KEY=sk-ant-...                      # shot planning AND ingestion
# Optional overrides (sane defaults in code):
# BVG_RENDERER_MODEL=chunkwise                    # 'chunkwise' (quality) | 'fw2step' (speed)
# BVG_RENDER_SECONDS_PER_SHOT=5.0
# BVG_CLAUDE_INGEST_MODEL=claude-opus-4-8
# BVG_MAX_CHARACTERS_PER_BOOK=60                  # registry cap (don't overflood the DB)
# BVG_MAX_LOCATIONS_PER_BOOK=40
# BVG_DB_SSL_CA=/home/ubuntu/supabase_ca.pem      # set automatically by start-vm.sh on the VM

# Supabase service_role/secret key — full DB access, SERVER-SIDE ONLY (never the
# browser). Unused by the current architecture (the VM connects via
# BVG_DATABASE_URL); set only for a privileged server path that must bypass RLS.
# SUPABASE_URL=https://<project-ref>.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=sb_secret_...

# -----------------------------------------------------------------------------
# GPU VM (the start scripts read these). Set VM_IP to the box's address so you
# never pass it on the command line; pass an IP arg only to override for a
# one-off box. See _docs/DEPLOY.md.
# -----------------------------------------------------------------------------
VM_IP=                                            # e.g. 216.81.248.109
VM_SSH_KEY="/abs/path/to/private_key.pem"
VM_USER=ubuntu                                    # 'ubuntu' or 'root', per the image
VM_PORT=22
