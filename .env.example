# Copy to .env and fill in values before running services/launcher.sh or make start

# SGLang inference server for Director (Llama-3-8B)
SGLANG_DIRECTOR_URL=http://localhost:30000

# Fish Audio S2 inference server for TTS
SGLANG_TTS_URL=http://localhost:30001

# CUDA device for AudioGen SFX model (loaded in-process by the SFX service)
SFX_GPU_DEVICE=cuda:2

# Internal service URLs used by the Mixer to call TTS and SFX
TTS_SERVICE_URL=http://localhost:8001
SFX_SERVICE_URL=http://localhost:8002

# Optional: directory containing speaker voice profile JSON files
# SPEAKER_PROFILES_DIR=/data/speaker_profiles
