# =============================================================================
# ShotBook — all configuration in one place.
#
# There are three runtime contexts; each reads its own gitignored file. Copy the
# relevant block into that file and fill in the values. Never commit real secrets.
#
#   1) frontend/.env.local        (Vite, browser)        VITE_*
#   2) <vm>:~/shotbook/.env       (renderer + ingestion) BVG_* + ANTHROPIC_API_KEY
#   3) scripts/deploy.config      (one-command deploy)    VM_* + the two secrets
# =============================================================================

# -----------------------------------------------------------------------------
# 1) FRONTEND  ->  frontend/.env.local
#    The React app talks directly to Supabase (data) and the VM renderer.
# -----------------------------------------------------------------------------
VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_xxx        # publishable/anon key (browser-safe)
VITE_VM_BASE_URL=http://localhost:8004           # SSH-tunnel the VM renderer to this

# -----------------------------------------------------------------------------
# 2) VM  ->  ~/shotbook/.env   (renderer shot-planning + ingestion)
#    DATABASE_URL uses the Supabase POOLER (the VM is IPv4-only); note aws-1.
# -----------------------------------------------------------------------------
BVG_DATABASE_URL=postgresql+asyncpg://postgres.<ref>:<password>@aws-1-us-east-1.pooler.supabase.com:5432/postgres
BVG_DB_SSL_CA=/home/ubuntu/supabase_ca.pem       # extracted by scripts/resume_vm.sh
ANTHROPIC_API_KEY=sk-ant-...                      # shot planning AND ingestion
# Optional overrides:
# BVG_RENDER_SECONDS_PER_SHOT=5.0
# BVG_CLAUDE_INGEST_MODEL=claude-opus-4-8

# -----------------------------------------------------------------------------
# 3) DEPLOY  ->  scripts/deploy.config   (run scripts/deploy.sh <VM_IP>)
#    Set once; only the IP changes per instance (passed on the command line).
# -----------------------------------------------------------------------------
VM_SSH_KEY="/abs/path/to/private_key.pem"
VM_USER=ubuntu                                    # 'ubuntu' or 'root', per the image
VM_PORT=22
# plus BVG_DATABASE_URL and ANTHROPIC_API_KEY (same values as block 2) so the
# deploy can write the VM's .env.
