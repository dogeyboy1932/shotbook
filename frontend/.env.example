# Frontend env — copy to .env.local (gitignored) and fill in.
# UI-first architecture: the React app talks directly to Supabase (data + the
# resolve_contexts RPC) and to the VM renderer (plan + render). No FastAPI.

# Supabase project (book/paragraph data + resolve_contexts RPC).
VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_xxx   # the publishable/anon key (browser-safe)

# VM renderer base URL. For local dev, SSH-tunnel the VM's :8004 to localhost:
#   ssh -N -L 8004:localhost:8004 <user>@<vm-ip> -i private_key.pem
VITE_VM_BASE_URL=http://localhost:8004
